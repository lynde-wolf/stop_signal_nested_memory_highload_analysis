# Copy this file to .env and fill in the paths for your local machine.
# .env is never committed to git — each collaborator maintains their own.

# Path to the processed data outputs folder (results, figures, preprocessed CSVs).
# Defaults to <project_root>/data if not set.
# STOPWM_DATADIR=/path/to/your/data

# Path to the raw participant JSON files downloaded from the experiment server.
# This folder should NOT be committed to git (it is in .gitignore).
# Defaults to <project_root>/raw_data if not set.
# STOPWM_RAWDATADIR=/path/to/your/raw_data
